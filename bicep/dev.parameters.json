{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "namePrefix":                  { "value": "llmplatform" },
    "workspaceName":               { "value": "llmplatform-logs" },
    "storageAccountName":          { "value": "llmplatformstorage" },
    "userIdentityName":            { "value": "llmplatform-identity" },
    "keyVaultName":                { "value": "llmplatform-vault" },
    "envName":                     { "value": "llmplatform-env" },
    "postgresServerName":          { "value": "llmplatform-pg" },
    "redisName":                   { "value": "llmplatform-redis" },
    "azureOpenAIName":             { "value": "llmplatform-openai" },
    "azureOpenAIApiVersion":       { "value": "2025-09-01" },
    "createAzureOpenAI":           { "value": true },
    "createOpenAIModels":          { "value": true },

    "openWebUIName":               { "value": "openwebui" },
    "openWebUIImage":              { "value": "ghcr.io/open-webui/open-webui:v0.9.2" },

    "litellmName":                 { "value": "litellm" },
    "litellmImage":                { "value": "docker.litellm.ai/berriai/litellm:main-v1.83.10-stable" },

    "deployLibreChat":             { "value": true },
    "libreChatName":               { "value": "librechat" },
    "libreChatImage":              { "value": "ghcr.io/danny-avila/librechat:v0.8.5" },
    "mongoAccountName":            { "value": "llmplatform-mongo" },

    "postgresPublicNetworkAccess": { "value": "Enabled" }
  }
}
